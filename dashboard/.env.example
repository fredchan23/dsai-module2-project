# Snowflake connection — copy to .env and fill in values
SNOWFLAKE_ACCOUNT=vrsugdf-gx74482
SNOWFLAKE_USER=dbt
SNOWFLAKE_ROLE=TRANSFORM
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=OLIST
SNOWFLAKE_SCHEMA=DEV

# Authentication — choose one method:
# Option A: private key (recommended)
SNOWFLAKE_PRIVATE_KEY_PATH=/path/to/rsa_key.p8
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=your_passphrase_here

# Option B: password (simpler for local dev)
# SNOWFLAKE_PASSWORD=your_password_here
