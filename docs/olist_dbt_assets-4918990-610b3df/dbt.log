{"data": {"conn_name": "model.olist.fct_order_items", "node_info": {"materialized": "table", "meta": {}, "node_checksum": "cae4964d88d8938e56e6d6b16fb7ee2c9b34337d70c5f3bd80081a12861947fe", "node_finished_at": "", "node_name": "fct_order_items", "node_path": "fct/fct_order_items.sql", "node_relation": {"alias": "fct_order_items", "database": "OLIST", "relation_name": "OLIST.DEV.fct_order_items", "schema": "DEV"}, "node_started_at": "2026-03-18T06:48:59.479628", "node_status": "executing", "resource_type": "model", "unique_id": "model.olist.fct_order_items"}, "sql": "create or replace transient table OLIST.DEV.fct_order_items\n    \n    \n    \n    as (with order_items as (\n    select order_id,\n        order_item_id,\n        product_id,\n        seller_id,\n        shipping_limit_ts,\n        item_price,\n        freight_value,\n        item_price + freight_value as total_item_value\n        from OLIST.DEV.src_order_items\n),\nproducts as (\n    select product_id,\n        product_category_name_english\n    from OLIST.DEV.dim_products\n),\nsellers as (\n    select seller_id,\n        seller_state\n    from OLIST.DEV.dim_sellers\n),\norders as (\n    select order_id,\n        customer_unique_id,\n        order_date,\n        order_status,\n        is_delivered,\n        is_late,\n        delivery_days\n    from OLIST.DEV.fct_orders\n)\nselect oi.order_id,\n    oi.order_item_id,\n    oi.product_id,\n    oi.seller_id,\n    o.customer_unique_id,\n    o.order_date,\n    o.order_status,\n    o.is_delivered,\n    o.is_late,\n    o.delivery_days,\n    oi.shipping_limit_ts,\n    oi.item_price,\n    oi.freight_value,\n    oi.total_item_value,\n    p.product_category_name_english,\n    s.seller_state\nfrom order_items as oi\n    left join orders as o on oi.order_id = o.order_id\n    left join products as p on oi.product_id = p.product_id\n    left join sellers as s on oi.seller_id = s.seller_id\n    )\n\n/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.7\", \"profile_name\": \"olist\", \"target_name\": \"dev\", \"node_id\": \"model.olist.fct_order_items\"} */;"}, "info": {"category": "", "code": "E016", "extra": {}, "invocation_id": "130a436f-5799-4bb6-9457-f4f8057abc76", "level": "debug", "msg": "On model.olist.fct_order_items: create or replace transient table OLIST.DEV.fct_order_items\n    \n    \n    \n    as (with order_items as (\n    select order_id,\n        order_item_id,\n        product_id,\n        seller_id,\n        shipping_limit_ts,\n        item_price,\n        freight_value,\n        item_price + freight_value as total_item_value\n        from OLIST.DEV.src_order_items\n),\nproducts as (\n    select product_id,\n        product_category_name_english\n    from OLIST.DEV.dim_products\n),\nsellers as (\n    select seller_id,\n        seller_state\n    from OLIST.DEV.dim_sellers\n),\norders as (\n    select order_id,\n        customer_unique_id,\n        order_date,\n        order_status,\n        is_delivered,\n        is_late,\n        delivery_days\n    from OLIST.DEV.fct_orders\n)\nselect oi.order_id,\n    oi.order_item_id,\n    oi.product_id,\n    oi.seller_id,\n    o.customer_unique_id,\n    o.order_date,\n    o.order_status,\n    o.is_delivered,\n    o.is_late,\n    o.delivery_days,\n    oi.shipping_limit_ts,\n    oi.item_price,\n    oi.freight_value,\n    oi.total_item_value,\n    p.product_category_name_english,\n    s.seller_state\nfrom order_items as oi\n    left join orders as o on oi.order_id = o.order_id\n    left join products as p on oi.product_id = p.product_id\n    left join sellers as s on oi.seller_id = s.seller_id\n    )\n\n/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.7\", \"profile_name\": \"olist\", \"target_name\": \"dev\", \"node_id\": \"model.olist.fct_order_items\"} */;", "name": "SQLQuery", "pid": 182467, "thread": "Thread-2 (worker)", "ts": "2026-03-18T06:48:59.491654Z"}}
