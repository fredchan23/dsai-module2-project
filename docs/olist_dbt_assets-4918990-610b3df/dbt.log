duct_category_name\n    )\n\n/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.7\", \"profile_name\": \"olist\", \"target_name\": \"dev\", \"node_id\": \"model.olist.dim_products\"} */;", "name": "SQLQuery", "pid": 182467, "thread": "Thread-2 (worker)", "ts": "2026-03-18T06:48:52.096923Z"}}
