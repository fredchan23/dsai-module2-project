{"data": {"conn_name": "model.olist.mart_delivery_performance", "node_info": {"materialized": "table", "meta": {}, "node_checksum": "45e28f0c06a97bad5466540821b163a286ff460273413bc19e676245af5b6da3", "node_finished_at": "", "node_name": "mart_delivery_performance", "node_path": "mart/mart_delivery_performance.sql", "node_relation": {"alias": "mart_delivery_performance", "database": "OLIST", "relation_name": "OLIST.DEV.mart_delivery_performance", "schema": "DEV"}, "node_started_at": "2026-03-18T06:48:58.391796", "node_status": "executing", "resource_type": "model", "unique_id": "model.olist.mart_delivery_performance"}, "sql": "create or replace transient table OLIST.DEV.mart_delivery_performance\n    \n    \n    \n    as (with eligible_deliveries as (\n    select\n        c.customer_state,\n        o.order_id,\n        o.is_late,\n        o.delivery_days,\n        o.days_to_ship,\n        o.revenue_incl_freight\n    from OLIST.DEV.fct_orders as o\n    left join OLIST.DEV.dim_customers as c\n        on o.customer_unique_id = c.customer_unique_id\n    where o.order_status = 'delivered'\n        and o.order_delivered_customer_ts is not null\n        and o.order_estimated_delivery_ts is not null\n)\nselect\n    customer_state,\n    count(*) as eligible_delivery_order_count,\n    sum(case when not is_late then 1 else 0 end) as on_time_delivery_order_count,\n    sum(case when is_late then 1 else 0 end) as late_delivery_order_count,\n    coalesce(\n        sum(case when not is_late then 1 else 0 end)::float / nullif(count(*), 0),\n        0\n    ) as on_time_delivery_rate,\n    avg(delivery_days) as average_delivery_days,\n    avg(days_to_ship) as average_days_to_ship,\n    sum(revenue_incl_freight) as revenue_incl_freight\nfrom eligible_deliveries\ngroup by 1\n    )\n\n/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.7\", \"profile_name\": \"olist\", \"target_name\": \"dev\", \"node_id\": \"model.olist.mart_delivery_performance\"} */;"}, "info": {"category": "", "code": "E016", "extra": {}, "invocation_id": "130a436f-5799-4bb6-9457-f4f8057abc76", "level": "debug", "msg": "On model.olist.mart_delivery_performance: create or replace transient table OLIST.DEV.mart_delivery_performance\n    \n    \n    \n    as (with eligible_deliveries as (\n    select\n        c.customer_state,\n        o.order_id,\n        o.is_late,\n        o.delivery_days,\n        o.days_to_ship,\n        o.revenue_incl_freight\n    from OLIST.DEV.fct_orders as o\n    left join OLIST.DEV.dim_customers as c\n        on o.customer_unique_id = c.customer_unique_id\n    where o.order_status = 'delivered'\n        and o.order_delivered_customer_ts is not null\n        and o.order_estimated_delivery_ts is not null\n)\nselect\n    customer_state,\n    count(*) as eligible_delivery_order_count,\n    sum(case when not is_late then 1 else 0 end) as on_time_delivery_order_count,\n    sum(case when is_late then 1 else 0 end) as late_delivery_order_count,\n    coalesce(\n        sum(case when not is_late then 1 else 0 end)::float / nullif(count(*), 0),\n        0\n    ) as on_time_delivery_rate,\n    avg(delivery_days) as average_delivery_days,\n    avg(days_to_ship) as average_days_to_ship,\n    sum(revenue_incl_freight) as revenue_incl_freight\nfrom eligible_deliveries\ngroup by 1\n    )\n\n/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.7\", \"profile_name\": \"olist\", \"target_name\": \"dev\", \"node_id\": \"model.olist.mart_delivery_performance\"} */;", "name": "SQLQuery", "pid": 182467, "thread": "Thread-2 (worker)", "ts": "2026-03-18T06:48:58.402856Z"}}
