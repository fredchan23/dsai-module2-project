{"data": {"conn_name": "model.olist.mart_top_products", "node_info": {"materialized": "table", "meta": {}, "node_checksum": "77fb2e024cb4b3504a92ac9e8e174550f657240413feb15393359596c55b6f8f", "node_finished_at": "", "node_name": "mart_top_products", "node_path": "mart/mart_top_products.sql", "node_relation": {"alias": "mart_top_products", "database": "OLIST", "relation_name": "OLIST.DEV.mart_top_products", "schema": "DEV"}, "node_started_at": "2026-03-18T06:49:08.043737", "node_status": "executing", "resource_type": "model", "unique_id": "model.olist.mart_top_products"}, "sql": "create or replace transient table OLIST.DEV.mart_top_products\n    \n    \n    \n    as (with product_performance as (\n    select\n        product_id,\n        min(product_category_name_english) as product_category_name_english,\n        count(distinct order_id) as order_count,\n        count(*) as units_sold,\n        sum(item_price) as gross_merchandise_value,\n        sum(total_item_value) as revenue_incl_freight\n    from OLIST.DEV.fct_order_items\n    group by 1\n)\nselect\n    product_id,\n    product_category_name_english,\n    order_count,\n    units_sold,\n    gross_merchandise_value,\n    revenue_incl_freight,\n    coalesce(revenue_incl_freight / nullif(units_sold, 0), 0) as average_unit_revenue,\n    dense_rank() over (order by revenue_incl_freight desc, product_id) as revenue_rank,\n    dense_rank() over (\n        partition by product_category_name_english\n        order by revenue_incl_freight desc, product_id\n    ) as category_revenue_rank\nfrom product_performance\n    )\n\n/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.7\", \"profile_name\": \"olist\", \"target_name\": \"dev\", \"node_id\": \"model.olist.mart_top_products\"} */;"}, "info": {"category": "", "code": "E016", "extra": {}, "invocation_id": "130a436f-5799-4bb6-9457-f4f8057abc76", "level": "debug", "msg": "On model.olist.mart_top_products: create or replace transient table OLIST.DEV.mart_top_products\n    \n    \n    \n    as (with product_performance as (\n    select\n        product_id,\n        min(product_category_name_english) as product_category_name_english,\n        count(distinct order_id) as order_count,\n        count(*) as units_sold,\n        sum(item_price) as gross_merchandise_value,\n        sum(total_item_value) as revenue_incl_freight\n    from OLIST.DEV.fct_order_items\n    group by 1\n)\nselect\n    product_id,\n    product_category_name_english,\n    order_count,\n    units_sold,\n    gross_merchandise_value,\n    revenue_incl_freight,\n    coalesce(revenue_incl_freight / nullif(units_sold, 0), 0) as average_unit_revenue,\n    dense_rank() over (order by revenue_incl_freight desc, product_id) as revenue_rank,\n    dense_rank() over (\n        partition by product_category_name_english\n        order by revenue_incl_freight desc, product_id\n    ) as category_revenue_rank\nfrom product_performance\n    )\n\n/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.7\", \"profile_name\": \"olist\", \"target_name\": \"dev\", \"node_id\": \"model.olist.mart_top_products\"} */;", "name": "SQLQuery", "pid": 182467, "thread": "Thread-2 (worker)", "ts": "2026-03-18T06:49:08.055322Z"}}
