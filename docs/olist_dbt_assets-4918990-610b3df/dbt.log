{"data": {"conn_name": "model.olist.dim_customers", "node_info": {"materialized": "table", "meta": {}, "node_checksum": "cfbaefc66240aea19997d62f9b7f4bea3a6661926d32decd8113a4fec8e053f5", "node_finished_at": "", "node_name": "dim_customers", "node_path": "dim/dim_customers.sql", "node_relation": {"alias": "dim_customers", "database": "OLIST", "relation_name": "OLIST.DEV.dim_customers", "schema": "DEV"}, "node_started_at": "2026-03-18T06:48:42.882510", "node_status": "executing", "resource_type": "model", "unique_id": "model.olist.dim_customers"}, "sql": "create or replace transient table OLIST.DEV.dim_customers\n    \n    \n    \n    as (with customer_base as (\n    select\n        customer_unique_id,\n        customer_id,\n        customer_zip_code_prefix,\n        customer_city,\n        customer_state,\n        row_number() over (\n            partition by customer_unique_id\n            order by customer_id desc\n        ) as rn,\n        count(distinct customer_id) over (\n            partition by customer_unique_id\n        ) as customer_id_count\n    from OLIST.DEV.src_customers\n)\n\nselect\n    customer_unique_id,\n    customer_id as representative_customer_id,\n    customer_zip_code_prefix,\n    customer_city,\n    customer_state,\n    customer_id_count\nfrom customer_base\nwhere rn = 1\n    )\n\n/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.7\", \"profile_name\": \"olist\", \"target_name\": \"dev\", \"node_id\": \"model.olist.dim_customers\"} */;"}, "info": {"category": "", "code": "E016", "extra": {}, "invocation_id": "130a436f-5799-4bb6-9457-f4f8057abc76", "level": "debug", "msg": "On model.olist.dim_customers: create or replace transient table OLIST.DEV.dim_customers\n    \n    \n    \n    as (with customer_base as (\n    select\n        customer_unique_id,\n        customer_id,\n        customer_zip_code_prefix,\n        customer_city,\n        customer_state,\n        row_number() over (\n            partition by customer_unique_id\n            order by customer_id desc\n        ) as rn,\n        count(distinct customer_id) over (\n            partition by customer_unique_id\n        ) as customer_id_count\n    from OLIST.DEV.src_customers\n)\n\nselect\n    customer_unique_id,\n    customer_id as representative_customer_id,\n    customer_zip_code_prefix,\n    customer_city,\n    customer_state,\n    customer_id_count\nfrom customer_base\nwhere rn = 1\n    )\n\n/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.7\", \"profile_name\": \"olist\", \"target_name\": \"dev\", \"node_id\": \"model.olist.dim_customers\"} */;", "name": "SQLQuery", "pid": 182467, "thread": "Thread-2 (worker)", "ts": "2026-03-18T06:48:42.911134Z"}}
