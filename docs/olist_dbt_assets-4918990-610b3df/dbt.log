{"data": {"conn_name": "model.olist.fct_orders", "node_info": {"materialized": "table", "meta": {}, "node_checksum": "a90fa81e054d88b89141bef0b928b96e5aec8f1239b3bdb79afae25a05641938", "node_finished_at": "", "node_name": "fct_orders", "node_path": "fct/fct_orders.sql", "node_relation": {"alias": "fct_orders", "database": "OLIST", "relation_name": "OLIST.DEV.fct_orders", "schema": "DEV"}, "node_started_at": "2026-03-18T06:48:45.200268", "node_status": "executing", "resource_type": "model", "unique_id": "model.olist.fct_orders"}, "sql": "create or replace transient table OLIST.DEV.fct_orders\n    \n    \n    \n    as (with item_agg as (\n    select order_id,\n        count(*) as order_item_count,\n        sum(item_price) as gmv,\n        sum(item_price + freight_value) as revenue_incl_freight\n     from OLIST.DEV.src_order_items\n    group by order_id\n),\npayment_agg as (\n    select order_id,\n        sum(payment_value) as total_payment_value,\n        count(*) as payment_count\n     from OLIST.DEV.src_order_payments\n    group by order_id\n),\nreview_agg as (\n    select order_id,\n        avg(review_score) as avg_review_score\n     from OLIST.DEV.src_order_reviews\n    group by order_id\n),\norders_enriched as (\n    select o.order_id,\n        o.customer_id,\n        c.customer_unique_id,\n        o.order_status,\n        o.order_purchase_ts,\n        o.order_approved_ts,\n        o.order_delivered_carrier_ts,\n        o.order_delivered_customer_ts,\n        o.order_estimated_delivery_ts,\n        coalesce(i.order_item_count, 0) as order_item_count,\n        coalesce(i.gmv, 0) as gmv,\n        coalesce(i.revenue_incl_freight, 0) as revenue_incl_freight,\n        coalesce(p.total_payment_value, 0) as total_payment_value,\n        coalesce(p.payment_count, 0) as payment_count,\n        r.avg_review_score,\n        case\n            when o.order_status = 'delivered' then true\n            else false\n        end as is_delivered,\n        case\n            when o.order_delivered_customer_ts > o.order_estimated_delivery_ts then true\n            else false\n        end as is_late,\n        datediff(\n            'day',\n            o.order_purchase_ts,\n            o.order_delivered_customer_ts\n        ) as delivery_days,\n        datediff(\n            'day',\n            o.order_purchase_ts,\n            o.order_delivered_carrier_ts\n        ) as days_to_ship,\n        1 as order_count\n    from OLIST.DEV.src_orders as o\n        left join OLIST.DEV.src_customers as c on o.customer_id = c.customer_id\n        left join item_agg as i on o.order_id = i.order_id\n        left join payment_agg as p on o.order_id = p.order_id\n        left join review_agg as r on o.order_id = r.order_id\n)\nselect order_id,\n    customer_id,\n    customer_unique_id,\n    cast(order_purchase_ts as date) as order_date,\n    order_status,\n    order_purchase_ts,\n    order_approved_ts,\n    order_delivered_carrier_ts,\n    order_delivered_customer_ts,\n    order_estimated_delivery_ts,\n    order_item_count,\n    gmv,\n    revenue_incl_freight,\n    total_payment_value,\n    payment_count,\n    avg_review_score,\n    is_delivered,\n    is_late,\n    delivery_days,\n    days_to_ship,\n    order_count\nfrom orders_enriched\n    )\n\n/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.7\", \"profile_name\": \"olist\", \"target_name\": \"dev\", \"node_id\": \"model.olist.fct_orders\"} */;"}, "info": {"category": "", "code": "E016", "extra": {}, "invocation_id": "130a436f-5799-4bb6-9457-f4f8057abc76", "level": "debug", "msg": "On model.olist.fct_orders: create or replace transient table OLIST.DEV.fct_orders\n    \n    \n    \n    as (with item_agg as (\n    select order_id,\n        count(*) as order_item_count,\n        sum(item_price) as gmv,\n        sum(item_price + freight_value) as revenue_incl_freight\n     from OLIST.DEV.src_order_items\n    group by order_id\n),\npayment_agg as (\n    select order_id,\n        sum(payment_value) as total_payment_value,\n        count(*) as payment_count\n     from OLIST.DEV.src_order_payments\n    group by order_id\n),\nreview_agg as (\n    select order_id,\n        avg(review_score) as avg_review_score\n     from OLIST.DEV.src_order_reviews\n    group by order_id\n),\norders_enriched as (\n    select o.order_id,\n        o.customer_id,\n        c.customer_unique_id,\n        o.order_status,\n        o.order_purchase_ts,\n        o.order_approved_ts,\n        o.order_delivered_carrier_ts,\n        o.order_delivered_customer_ts,\n        o.order_estimated_delivery_ts,\n        coalesce(i.order_item_count, 0) as order_item_count,\n        coalesce(i.gmv, 0) as gmv,\n        coalesce(i.revenue_incl_freight, 0) as revenue_incl_freight,\n        coalesce(p.total_payment_value, 0) as total_payment_value,\n        coalesce(p.payment_count, 0) as payment_count,\n        r.avg_review_score,\n        case\n            when o.order_status = 'delivered' then true\n            else false\n        end as is_delivered,\n        case\n            when o.order_delivered_customer_ts > o.order_estimated_delivery_ts then true\n            else false\n        end as is_late,\n        datediff(\n            'day',\n            o.order_purchase_ts,\n            o.order_delivered_customer_ts\n        ) as delivery_days,\n        datediff(\n            'day',\n            o.order_purchase_ts,\n            o.order_delivered_carrier_ts\n        ) as days_to_ship,\n        1 as order_count\n    from OLIST.DEV.src_orders as o\n        left join OLIST.DEV.src_customers as c on o.customer_id = c.customer_id\n        left join item_agg as i on o.order_id = i.order_id\n        left join payment_agg as p on o.order_id = p.order_id\n        left join review_agg as r on o.order_id = r.order_id\n)\nselect order_id,\n    customer_id,\n    customer_unique_id,\n    cast(order_purchase_ts as date) as order_date,\n    order_status,\n    order_purchase_ts,\n    order_approved_ts,\n    order_delivered_carrier_ts,\n    order_delivered_customer_ts,\n    order_estimated_delivery_ts,\n    order_item_count,\n    gmv,\n    revenue_incl_freight,\n    total_payment_value,\n    payment_count,\n    avg_review_score,\n    is_delivered,\n    is_late,\n    delivery_days,\n    days_to_ship,\n    order_count\nfrom orders_enriched\n    )\n\n/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.7\", \"profile_name\": \"olist\", \"target_name\": \"dev\", \"node_id\": \"model.olist.fct_orders\"} */;", "name": "SQLQuery", "pid": 182467, "thread": "Thread-2 (worker)", "ts": "2026-03-18T06:48:45.214872Z"}}
