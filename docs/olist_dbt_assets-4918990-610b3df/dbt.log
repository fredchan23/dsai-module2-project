{"data": {"conn_name": "model.olist.mart_customer_rfm_scored", "node_info": {"materialized": "table", "meta": {}, "node_checksum": "fdea60865040d87f1fc876e1589f01b37f1daa4c61c55f8fcfe285ef72ef1888", "node_finished_at": "", "node_name": "mart_customer_rfm_scored", "node_path": "mart/mart_customer_rfm_scored.sql", "node_relation": {"alias": "mart_customer_rfm_scored", "database": "OLIST", "relation_name": "OLIST.DEV.mart_customer_rfm_scored", "schema": "DEV"}, "node_started_at": "2026-03-18T06:49:06.346005", "node_status": "executing", "resource_type": "model", "unique_id": "model.olist.mart_customer_rfm_scored"}, "sql": "create or replace transient table OLIST.DEV.mart_customer_rfm_scored\n    \n    \n    \n    as (with scored as (\n    select\n        customer_unique_id,\n        customer_state,\n        first_order_date,\n        last_order_date,\n        recency_days,\n        frequency_orders,\n        monetary_value,\n        average_order_value,\n        rfm_snapshot_date,\n        6 - ntile(5) over (order by recency_days asc, customer_unique_id) as recency_score,\n        ntile(5) over (order by frequency_orders asc, customer_unique_id) as frequency_score,\n        ntile(5) over (order by monetary_value asc, customer_unique_id) as monetary_score\n    from OLIST.DEV.mart_customer_rfm_raw\n)\nselect\n    customer_unique_id,\n    customer_state,\n    first_order_date,\n    last_order_date,\n    recency_days,\n    frequency_orders,\n    monetary_value,\n    average_order_value,\n    rfm_snapshot_date,\n    recency_score,\n    frequency_score,\n    monetary_score,\n    concat(recency_score, frequency_score, monetary_score) as rfm_score_code,\n    case\n        when recency_score >= 4 and frequency_score >= 4 and monetary_score >= 4 then 'champions'\n        when recency_score >= 3 and frequency_score >= 4 and monetary_score >= 3 then 'loyal_customers'\n        when recency_score = 5 and frequency_score <= 2 then 'recent_customers'\n        when recency_score <= 2 and frequency_score >= 4 and monetary_score >= 3 then 'at_risk'\n        when recency_score <= 2 and frequency_score <= 2 then 'hibernating'\n        else 'potential_loyalists'\n    end as segment_label\nfrom scored\n    )\n\n/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.7\", \"profile_name\": \"olist\", \"target_name\": \"dev\", \"node_id\": \"model.olist.mart_customer_rfm_scored\"} */;"}, "info": {"category": "", "code": "E016", "extra": {}, "invocation_id": "130a436f-5799-4bb6-9457-f4f8057abc76", "level": "debug", "msg": "On model.olist.mart_customer_rfm_scored: create or replace transient table OLIST.DEV.mart_customer_rfm_scored\n    \n    \n    \n    as (with scored as (\n    select\n        customer_unique_id,\n        customer_state,\n        first_order_date,\n        last_order_date,\n        recency_days,\n        frequency_orders,\n        monetary_value,\n        average_order_value,\n        rfm_snapshot_date,\n        6 - ntile(5) over (order by recency_days asc, customer_unique_id) as recency_score,\n        ntile(5) over (order by frequency_orders asc, customer_unique_id) as frequency_score,\n        ntile(5) over (order by monetary_value asc, customer_unique_id) as monetary_score\n    from OLIST.DEV.mart_customer_rfm_raw\n)\nselect\n    customer_unique_id,\n    customer_state,\n    first_order_date,\n    last_order_date,\n    recency_days,\n    frequency_orders,\n    monetary_value,\n    average_order_value,\n    rfm_snapshot_date,\n    recency_score,\n    frequency_score,\n    monetary_score,\n    concat(recency_score, frequency_score, monetary_score) as rfm_score_code,\n    case\n        when recency_score >= 4 and frequency_score >= 4 and monetary_score >= 4 then 'champions'\n        when recency_score >= 3 and frequency_score >= 4 and monetary_score >= 3 then 'loyal_customers'\n        when recency_score = 5 and frequency_score <= 2 then 'recent_customers'\n        when recency_score <= 2 and frequency_score >= 4 and monetary_score >= 3 then 'at_risk'\n        when recency_score <= 2 and frequency_score <= 2 then 'hibernating'\n        else 'potential_loyalists'\n    end as segment_label\nfrom scored\n    )\n\n/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.7\", \"profile_name\": \"olist\", \"target_name\": \"dev\", \"node_id\": \"model.olist.mart_customer_rfm_scored\"} */;", "name": "SQLQuery", "pid": 182467, "thread": "Thread-2 (worker)", "ts": "2026-03-18T06:49:06.356215Z"}}
